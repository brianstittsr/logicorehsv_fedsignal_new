rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserRole() {
      // TODO: Implement proper role lookup from team_members collection
      // For now, treat all authenticated users as admins for development
      return isAuthenticated() ? 'admin' : null;
    }
    
    function isAdmin() {
      // During development, all authenticated users have admin access
      return isAuthenticated();
    }
    
    function isTeamMember() {
      // During development, all authenticated users are team members
      return isAuthenticated();
    }
    
    function isAffiliate() {
      // During development, all authenticated users can be affiliates
      return isAuthenticated();
    }
    
    function isOrgMember(orgId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.organizationId == orgId;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Organizations collection
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow create: if isTeamMember();
      allow update: if isTeamMember() || isOrgMember(orgId);
      allow delete: if isAdmin();
      
      // Certifications subcollection
      match /certifications/{certId} {
        allow read: if isAuthenticated();
        allow write: if isTeamMember() || isOrgMember(orgId);
      }
      
      // Capabilities subcollection
      match /capabilities/{capId} {
        allow read: if isAuthenticated();
        allow write: if isTeamMember() || isOrgMember(orgId);
      }
    }

    // Opportunities collection
    // TODO: Restrict to role-based access in production
    match /opportunities/{oppId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Projects collection
    // TODO: Restrict to role-based access in production
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
      
      // Milestones subcollection
      match /milestones/{milestoneId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Meetings collection
    // TODO: Restrict to role-based access in production
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
      
      // Action items subcollection
      match /actionItems/{actionId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Action Items collection (top-level)
    // TODO: Restrict to role-based access in production
    match /actionItems/{actionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Rocks collection
    // TODO: Restrict to role-based access in production
    match /rocks/{rockId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
      
      // Rock milestones subcollection
      match /milestones/{milestoneId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    // Documents collection
    // TODO: Restrict to role-based access in production
    match /documents/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Services collection
    match /services/{serviceId} {
      allow read: if true; // Public read for marketing
      allow write: if isAdmin();
    }

    // Activities collection
    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Notes collection
    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if resource.data.authorId == request.auth.uid || isAdmin();
      allow delete: if resource.data.authorId == request.auth.uid || isAdmin();
    }

    // =========================================================================
    // Affiliate Networking System Collections
    // =========================================================================

    // Affiliate Biographies - affiliates can manage their own
    match /affiliateBiographies/{bioId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.affiliateId == request.auth.uid;
      allow update: if resource.data.affiliateId == request.auth.uid || isAdmin();
      allow delete: if isAdmin();
    }

    // GAINS Profiles - affiliates can manage their own
    match /gainsProfiles/{profileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.affiliateId == request.auth.uid;
      allow update: if resource.data.affiliateId == request.auth.uid || isAdmin();
      allow delete: if isAdmin();
    }

    // Contact Spheres - affiliates can manage their own
    match /contactSpheres/{sphereId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.affiliateId == request.auth.uid;
      allow update: if resource.data.affiliateId == request.auth.uid || isAdmin();
      allow delete: if isAdmin();
    }

    // Previous Customers - affiliates can manage their own
    match /previousCustomers/{customersId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.affiliateId == request.auth.uid;
      allow update: if resource.data.affiliateId == request.auth.uid || isAdmin();
      allow delete: if isAdmin();
    }

    // One-to-One Meetings - participants can read/update
    match /oneToOneMeetings/{meetingId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.initiatorId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        resource.data.initiatorId == request.auth.uid ||
        resource.data.partnerId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // Referrals - referrer and recipient can access
    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.referrerId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isAdmin() ||
        resource.data.referrerId == request.auth.uid ||
        resource.data.recipientId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // Affiliate Stats - affiliates can read their own, admins can read all
    match /affiliateStats/{statsId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.affiliateId == request.auth.uid
      );
      allow create: if isAdmin();
      allow update: if isAdmin(); // Stats are updated by system/admin
      allow delete: if isAdmin();
    }

    // AI Match Suggestions - affiliates can read their own suggestions
    match /aiMatchSuggestions/{suggestionId} {
      allow read: if isAuthenticated() && (
        isAdmin() ||
        resource.data.affiliateId == request.auth.uid
      );
      allow create: if isAdmin(); // Only system creates suggestions
      allow update: if isAuthenticated() && (
        isAdmin() ||
        resource.data.affiliateId == request.auth.uid // Can accept/decline
      );
      allow delete: if isAdmin();
    }

    // =========================================================================
    // Strategic Partners
    // =========================================================================

    // Strategic Partners - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /strategicPartners/{partnerId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Team Members - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /teamMembers/{memberId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Platform Settings - read/write allowed for development
    // TODO: Restrict writes to authenticated users in production
    match /platformSettings/{settingsId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // =========================================================================
    // Apollo Integration Collections
    // =========================================================================

    // Apollo Purchased Contacts - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /apolloPurchasedContacts/{contactId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Apollo Saved Lists - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /apolloSavedLists/{listId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // =========================================================================
    // ThomasNet Supplier Search Collections
    // =========================================================================

    // ThomasNet Saved Suppliers - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /thomasnetSavedSuppliers/{supplierId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // ThomasNet Saved Lists - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /thomasnetSavedLists/{listId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // =========================================================================
    // Networking Profile Collections
    // =========================================================================

    // Affiliate Biographies - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /affiliateBiographies/{bioId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // GAINS Profiles - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /gainsProfiles/{profileId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Contact Spheres - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /contactSpheres/{sphereId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // Previous Customers - read/write allowed for development
    // TODO: Restrict to authenticated users in production
    match /previousCustomers/{customersId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // =========================================================================
    // Software License Keys
    // =========================================================================

    // Software Keys - admin only for management
    match /softwareKeys/{keyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Key Activations - track key usage
    match /keyActivations/{activationId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // =========================================================================
    // White-Label Deployments
    // =========================================================================

    // White-Label Deployments - admin management
    match /whiteLabelDeployments/{deploymentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Deployment Analytics
    match /deploymentAnalytics/{analyticsId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Deployment Audit Logs
    match /deploymentAuditLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if false;
    }

    // =========================================================================
    // GoHighLevel Integration Collections
    // TODO: Restrict to authenticated users in production
    // =========================================================================

    // GoHighLevel Integrations - open for development
    match /gohighlevelIntegrations/{integrationId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // GoHighLevel Sync Logs - open for development
    match /gohighlevelSyncLogs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // GoHighLevel Workflows - open for development
    match /ghlWorkflows/{workflowId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // GoHighLevel Imported Workflows - open for development
    match /ghlImportedWorkflows/{workflowId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // =========================================================================
    // Calendar & Scheduling Collections
    // TODO: Restrict to authenticated users in production
    // =========================================================================

    // Calendar Events - open for development
    match /calendarEvents/{eventId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // 1-to-1 Scheduling Queue - open for development
    match /oneToOneQueue/{queueId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Team Member Availability - open for development
    match /teamMemberAvailability/{availabilityId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Bookings - open for development
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // GHL Calendar Events Cache - open for development
    match /ghlCalendarEvents/{eventId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // GHL Sync Status - open for development
    match /ghlSyncStatus/{statusId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // =========================================================================
    // Traction/EOS2 Collections
    // TODO: Restrict to authenticated users in production
    // =========================================================================

    // Traction Rocks - open for development
    match /tractionRocks/{rockId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Traction Scorecard Metrics - open for development
    match /tractionScorecardMetrics/{metricId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Traction Issues - open for development
    match /tractionIssues/{issueId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Traction Todos - open for development
    match /tractionTodos/{todoId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Traction Meetings - open for development
    match /tractionMeetings/{meetingId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Traction Team Members - open for development
    match /tractionTeamMembers/{memberId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // =========================================================================
    // Mattermost Playbooks Collections
    // TODO: Restrict to authenticated users in production
    // =========================================================================

    // Mattermost Playbooks - open for development
    match /mattermostPlaybooks/{playbookId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Mattermost Playbook Runs - open for development
    match /mattermostPlaybookRuns/{runId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // =========================================================================
    // Image Assets Collection
    // =========================================================================

    // Image Assets - for Image Manager
    match /image_assets/{imageId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Leadership Members - for Leadership page management
    match /leadership_members/{memberId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // =========================================================================
    // Page Designer Collections
    // =========================================================================

    // Page Designs - for AI Page Designer
    match /page_designs/{pageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Navigation Config - for Navigation Manager
    match /navigation_config/{configId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // =========================================================================
    // Webinars Collection
    // =========================================================================

    // Webinars - open for development
    match /webinars/{webinarId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // Hero Slides - for Hero Carousel
    match /heroSlides/{slideId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }

    // =========================================================================
    // Proposals and E-Signatures
    // =========================================================================

    // Proposals - authenticated users can read/write for development
    match /proposals/{proposalId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // Proposal Signatures - for e-signature workflow
    match /proposalSignatures/{signatureId} {
      allow read: if true; // Public read for signing page access
      allow create: if isAuthenticated();
      allow update: if true; // Allow updates for signature completion
      allow delete: if isAuthenticated();
    }

    // =========================================================================
    // FedSignal Collections - Multi-tenant HBCU Research & Contracting Hub
    // =========================================================================

    // Helper function to check university membership
    function belongsToUniversity(universityId) {
      return isAuthenticated() && 
        (resource.data.university_id == universityId ||
         request.resource.data.university_id == universityId);
    }

    // 1. Opportunities
    match /fedsignal_opportunities/{oppId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow delete: if isAdmin();
    }

    // 2. Grants
    match /fedsignal_grants/{grantId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // 3. SBIR Awards
    match /fedsignal_sbir_awards/{awardId} {
      allow read: if true; // Public read
      allow create, update, delete: if isAdmin();
    }

    // 4. Alerts
    match /fedsignal_alerts/{alertId} {
      allow read: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.user_id == request.auth.uid ||
        request.auth.token.role == 'admin'
      );
      allow delete: if isAdmin();
    }

    // 5. Capabilities
    match /fedsignal_capabilities/{capId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 6. Teaming Partners
    match /fedsignal_teaming_partners/{partnerId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // 7. Consortiums
    match /fedsignal_consortiums/{consortiumId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // 8. RFIs
    match /fedsignal_rfis/{rfiId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // 9. Proposals
    match /fedsignal_proposals/{proposalId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow delete: if isAdmin();
      
      // Subcollections for proposal
      match /versions/{versionId} {
        allow read, write: if isAuthenticated();
      }
    }

    // 10. Subcontracts
    match /fedsignal_subcontracts/{subId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 11. Scorecards
    match /fedsignal_scorecards/{scorecardId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated();
    }

    // 12. Win/Loss Records
    match /fedsignal_win_loss/{recordId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // 13. F&A Records
    match /fedsignal_fanda_records/{recordId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 14. GammaDeck Cards
    match /fedsignal_gammadeck_cards/{cardId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 15. Directory Entries
    match /fedsignal_directory_entries/{entryId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 16. Events
    match /fedsignal_events/{eventId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 17. Tasks
    match /fedsignal_tasks/{taskId} {
      allow read: if isAuthenticated() && (
        resource.data.assigned_to == request.auth.uid ||
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.assigned_to == request.auth.uid ||
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow delete: if isAdmin();
    }

    // 18. Contacts
    match /fedsignal_contacts/{contactId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 19. Newsletters
    match /fedsignal_newsletters/{newsletterId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 20. Content Assets
    match /fedsignal_content_assets/{assetId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 21. CAPVault Documents
    match /fedsignal_capvault_docs/{docId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 22. Leadership Profiles
    match /fedsignal_leadership_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 23. Board Members
    match /fedsignal_board_members/{memberId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // 24. Marketplace Listings
    match /fedsignal_marketplace_listings/{listingId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (
        resource.data.provider_university == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }

    // 25. Onboarding Flows
    match /fedsignal_onboarding_flows/{flowId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // 26. Invites
    match /fedsignal_invites/{inviteId} {
      allow read: if isAuthenticated() && (
        resource.data.invited_email == request.auth.token.email ||
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.invited_email == request.auth.token.email ||
        request.auth.token.role == 'admin'
      );
      allow delete: if isAdmin();
    }

    // 27. Contracts
    match /fedsignal_contracts/{contractId} {
      allow read: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
      allow create, update, delete: if isAuthenticated() && (
        resource.data.university_id == request.auth.token.university_id ||
        request.auth.token.role == 'admin'
      );
    }
  }
}
